---
import '../styles/medrese.css';
import {
  getMedreseCopy,
  localize,
  medreseItems,
  medreseLanguages,
  medreseLanguageLabels,
  medreseSections,
  type MedreseLang,
} from '../data/medrese';

interface Props {
  lang: MedreseLang;
  title?: string;
  description?: string;
  path?: string;
}

const {
  lang,
  title = 'Medrese',
  description = localize(medreseSections[0].description, lang),
  path = '',
} = Astro.props;
const copy = getMedreseCopy(lang);
const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? 'https://empyr-portfolio.com';
const canonical = `${siteUrl}/${lang}/medrese${path}/`;
const routeSuffix = Astro.url.pathname.split('/').slice(2).join('/');
const searchIndex = medreseItems.map((item) => ({
  id: item.id,
  section: item.section,
  title: localize(item.title, lang),
  summary: localize(item.summary, lang),
  meta: localize(item.meta, lang),
  tags: item.tags,
  href: `/${lang}/medrese/${item.section}/#${item.id}`,
}));
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} · Medrese</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {medreseLanguages.map((language) => (
      <link rel="alternate" hreflang={language} href={`${siteUrl}/${language}/medrese${path}/`} />
    ))}
    <link rel="alternate" hreflang="x-default" href={`${siteUrl}/nl/medrese${path}/`} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Medrese" />
    <meta property="og:title" content={`${title} · Medrese`} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={`${siteUrl}/images/empyr-logo.png`} />
    <meta property="og:locale" content={lang === 'tr' ? 'tr_TR' : lang === 'nl' ? 'nl_NL' : 'en_US'} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={`${title} · Medrese`} />
    <meta name="twitter:description" content={description} />
    <meta name="theme-color" content="#0f5b49" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Source+Serif+4:opsz,wght@8..60,500;8..60,600;8..60,700&display=swap"
      rel="stylesheet"
    />
    <script is:inline>
      (() => {
        const saved = localStorage.getItem('medrese-theme');
        const dark = saved ? saved === 'dark' : window.matchMedia('(prefers-color-scheme: dark)').matches;
        document.documentElement.dataset.medreseTheme = dark ? 'dark' : 'light';
      })();
    </script>
    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'EducationalOrganization',
        name: 'Medrese',
        url: `${siteUrl}/${lang}/medrese/`,
        description,
        availableLanguage: ['Dutch', 'Turkish', 'English'],
        isAccessibleForFree: true,
      })}
    />
  </head>
  <body class="medrese-body">
    <header class="sticky top-0 z-50 border-b med-border bg-[color:var(--med-bg)]/90 backdrop-blur-xl">
      <div class="mx-auto flex max-w-7xl items-center justify-between px-4 py-3.5 sm:px-6 lg:px-8">
        <a href={`/${lang}/medrese/`} class="flex items-center gap-3" aria-label={`${copy.siteName} home`}>
          <span class="relative flex h-10 w-10 items-center justify-center overflow-hidden rounded-2xl med-primary-bg text-[color:var(--med-bg)] shadow-lg">
            <svg viewBox="0 0 32 32" class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
              <path d="M7 8.5c3.7 0 6.8.8 9 2.7 2.2-1.9 5.3-2.7 9-2.7v15c-3.8 0-6.8.8-9 2.8-2.2-2-5.2-2.8-9-2.8v-15Z" />
              <path d="M16 11.2v15M10.5 12.5c2 .1 3.4.5 4.4 1.2M21.5 12.5c-2 .1-3.4.5-4.4 1.2" />
            </svg>
          </span>
          <span>
            <span class="med-serif block text-xl font-bold leading-none tracking-tight">{copy.siteName}</span>
            <span class="med-kicker mt-1 block text-[8px]">Ilm · Iman · İrfan</span>
          </span>
        </a>

        <nav class="hidden items-center gap-7 lg:flex" aria-label="Main navigation">
          <a href={`/${lang}/medrese/basiskennis/`} class="text-sm font-semibold med-muted transition hover:text-[color:var(--med-primary)]">{copy.navLearn}</a>
          <a href={`/${lang}/medrese/bibliotheek/`} class="text-sm font-semibold med-muted transition hover:text-[color:var(--med-primary)]">{copy.navLibrary}</a>
          <a href={`/${lang}/medrese/evenementen/`} class="text-sm font-semibold med-muted transition hover:text-[color:var(--med-primary)]">{copy.navActivities}</a>
          <a href={`/${lang}/medrese/risale/`} class="text-sm font-semibold med-muted transition hover:text-[color:var(--med-primary)]">{copy.navAbout}</a>
        </nav>

        <div class="flex items-center gap-2">
          <button type="button" class="flex h-10 w-10 items-center justify-center rounded-full border med-border med-surface" data-med-search-open aria-label={copy.search}>
            <svg viewBox="0 0 24 24" class="h-4.5 w-4.5" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
              <circle cx="11" cy="11" r="6.5"></circle><path d="m16 16 4 4"></path>
            </svg>
          </button>
          <button type="button" class="flex h-10 w-10 items-center justify-center rounded-full border med-border med-surface" data-med-theme aria-label={copy.theme}>
            <svg data-theme-moon viewBox="0 0 24 24" class="h-4.5 w-4.5" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
              <path d="M20 15.2A8.5 8.5 0 1 1 8.8 4a7 7 0 0 0 11.2 11.2Z"></path>
            </svg>
          </button>
          <div class="hidden items-center rounded-full border med-border med-surface p-1 sm:flex">
            {medreseLanguages.map((language) => (
              <a
                href={`/${language}/${routeSuffix}`}
                class="rounded-full px-2.5 py-1.5 text-[10px] font-extrabold uppercase transition"
                style={language === lang ? 'background: var(--med-primary); color: var(--med-bg);' : 'color: var(--med-muted);'}
                title={medreseLanguageLabels[language]}
              >
                {language}
              </a>
            ))}
          </div>
          <button type="button" class="flex h-10 w-10 items-center justify-center rounded-full border med-border med-surface lg:hidden" data-med-menu aria-label="Menu" aria-expanded="false">
            <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
              <path d="M4 7h16M4 12h16M4 17h16"></path>
            </svg>
          </button>
        </div>
      </div>

      <div class="border-t med-border med-surface lg:hidden" data-med-mobile-nav hidden>
        <nav class="mx-auto grid max-w-7xl gap-1 px-4 py-4" aria-label="Mobile navigation">
          <a href={`/${lang}/medrese/basiskennis/`} class="rounded-xl px-3 py-2.5 text-sm font-semibold hover:med-surface-soft">{copy.navLearn}</a>
          <a href={`/${lang}/medrese/bibliotheek/`} class="rounded-xl px-3 py-2.5 text-sm font-semibold hover:med-surface-soft">{copy.navLibrary}</a>
          <a href={`/${lang}/medrese/evenementen/`} class="rounded-xl px-3 py-2.5 text-sm font-semibold hover:med-surface-soft">{copy.navActivities}</a>
          <a href={`/${lang}/medrese/risale/`} class="rounded-xl px-3 py-2.5 text-sm font-semibold hover:med-surface-soft">{copy.navAbout}</a>
          <div class="mt-2 flex gap-2 border-t med-border pt-3">
            {medreseLanguages.map((language) => (
              <a href={`/${language}/${routeSuffix}`} class="rounded-full border med-border px-3 py-1.5 text-xs font-bold uppercase">{language}</a>
            ))}
          </div>
        </nav>
      </div>
    </header>

    <slot />

    <footer class="border-t med-border">
      <div class="mx-auto flex max-w-7xl flex-col gap-6 px-4 py-10 sm:px-6 md:flex-row md:items-center md:justify-between lg:px-8">
        <div>
          <p class="med-serif text-lg font-bold">{copy.siteName}</p>
          <p class="mt-1 text-xs med-muted">{copy.footer}</p>
        </div>
        <div class="flex flex-wrap gap-5 text-xs font-semibold med-muted">
          <button type="button" data-med-rights class="hover:med-primary">{copy.rights}</button>
          <a href={`/${lang}/medrese/admin/`} class="hover:med-primary">{copy.adminLink}</a>
          <a href={`/${lang}/`} class="hover:med-primary">{copy.backPortfolio}</a>
          <a href="mailto:business@empyr-portfolio.com" class="hover:med-primary">Contact</a>
        </div>
      </div>
    </footer>

    <div class="med-modal fixed inset-0 z-[100] bg-black/55 p-4 backdrop-blur-sm" data-med-search-modal hidden>
      <div class="mx-auto mt-[8vh] max-w-2xl overflow-hidden rounded-[1.7rem] border med-border med-surface shadow-2xl" role="dialog" aria-modal="true" aria-label={copy.search}>
        <div class="flex items-center gap-3 border-b med-border p-4">
          <svg viewBox="0 0 24 24" class="h-5 w-5 med-muted" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
            <circle cx="11" cy="11" r="6.5"></circle><path d="m16 16 4 4"></path>
          </svg>
          <input class="min-w-0 flex-1 bg-transparent py-2 text-base outline-none" data-med-search-input placeholder={copy.searchPlaceholder} />
          <button type="button" data-med-search-close class="rounded-lg border med-border px-2 py-1 text-xs med-muted">Esc</button>
        </div>
        <div class="max-h-[58vh] overflow-y-auto p-3" data-med-search-results>
          <p class="px-3 py-8 text-center text-sm med-muted">{copy.searchPlaceholder}</p>
        </div>
      </div>
    </div>

    <div class="med-modal fixed inset-0 z-[100] flex items-center justify-center bg-black/55 p-4 backdrop-blur-sm" data-med-rights-modal hidden>
      <div class="max-w-lg rounded-[1.7rem] border med-border med-surface p-7 shadow-2xl" role="dialog" aria-modal="true" aria-labelledby="rights-title">
        <div class="flex items-start justify-between gap-5">
          <div>
            <p class="med-kicker">{copy.rights}</p>
            <h2 id="rights-title" class="med-serif mt-2 text-3xl font-bold">{copy.rights}</h2>
          </div>
          <button type="button" data-med-rights-close class="flex h-9 w-9 items-center justify-center rounded-full border med-border" aria-label="Close">×</button>
        </div>
        <p class="mt-5 text-sm leading-7 med-muted">{copy.rightsBody}</p>
        <div class="mt-6 rounded-2xl med-surface-soft p-4 text-xs leading-6 med-muted">
          Risale-i Nur: metadata and original summaries only · Quran: references with original paraphrases · Hadith: collection references and educational summaries.
        </div>
      </div>
    </div>

    <script is:inline type="application/json" id="med-search-data" set:html={JSON.stringify(searchIndex)} />
    <script is:inline define:vars={{ noResults: copy.noResults }}>
      (() => {
        const root = document.documentElement;
        const themeButton = document.querySelector('[data-med-theme]');
        themeButton?.addEventListener('click', () => {
          const next = root.dataset.medreseTheme === 'dark' ? 'light' : 'dark';
          root.dataset.medreseTheme = next;
          localStorage.setItem('medrese-theme', next);
        });

        const menuButton = document.querySelector('[data-med-menu]');
        const mobileNav = document.querySelector('[data-med-mobile-nav]');
        menuButton?.addEventListener('click', () => {
          const open = mobileNav?.hasAttribute('hidden') ?? true;
          mobileNav?.toggleAttribute('hidden', !open);
          menuButton.setAttribute('aria-expanded', String(open));
        });

        const searchModal = document.querySelector('[data-med-search-modal]');
        const searchInput = document.querySelector('[data-med-search-input]');
        const resultBox = document.querySelector('[data-med-search-results]');
        const dataElement = document.getElementById('med-search-data');
        let data = dataElement ? JSON.parse(dataElement.textContent || '[]') : [];
        try {
          const adminRaw = localStorage.getItem('medrese-admin-content');
          if (adminRaw) {
            const adminItems = JSON.parse(adminRaw);
            const langMatch = window.location.pathname.split('/')[1] || 'nl';
            const adminIndex = adminItems.map((item) => ({
              id: item.id,
              section: item.section,
              title: item.title?.[langMatch] || item.title?.en || '',
              summary: item.summary?.[langMatch] || item.summary?.en || '',
              meta: item.meta?.[langMatch] || item.meta?.en || '',
              tags: item.tags || [],
              href: `/${langMatch}/medrese/${item.section}/#${item.id}`,
            }));
            data = [...adminIndex, ...data];
          }
        } catch {
          /* ignore malformed admin storage */
        }

        const closeSearch = () => {
          searchModal?.setAttribute('hidden', '');
          document.documentElement.style.overflow = '';
        };
        document.querySelector('[data-med-search-open]')?.addEventListener('click', () => {
          searchModal?.removeAttribute('hidden');
          document.documentElement.style.overflow = 'hidden';
          setTimeout(() => searchInput?.focus(), 50);
        });
        document.querySelector('[data-med-search-close]')?.addEventListener('click', closeSearch);
        searchModal?.addEventListener('click', (event) => {
          if (event.target === searchModal) closeSearch();
        });
        document.addEventListener('keydown', (event) => {
          if (event.key === 'Escape') closeSearch();
          if ((event.ctrlKey || event.metaKey) && event.key.toLowerCase() === 'k') {
            event.preventDefault();
            document.querySelector('[data-med-search-open]')?.click();
          }
        });
        searchInput?.addEventListener('input', () => {
          const query = searchInput.value.trim().toLowerCase();
          if (!query) {
            resultBox.innerHTML = `<p class="px-3 py-8 text-center text-sm med-muted">${searchInput.placeholder}</p>`;
            return;
          }
          const matches = data.filter((item) =>
            `${item.title} ${item.summary} ${item.tags.join(' ')}`.toLowerCase().includes(query)
          );
          resultBox.innerHTML = matches.length
            ? matches.slice(0, 8).map((item) => `
                <a href="${item.href}" class="block rounded-2xl p-4 hover:med-surface-soft">
                  <span class="text-[10px] font-bold uppercase tracking-wider med-accent">${item.section}</span>
                  <strong class="mt-1 block text-sm">${item.title}</strong>
                  <span class="mt-1 block text-xs leading-5 med-muted">${item.summary}</span>
                </a>`).join('')
            : `<p class="px-3 py-8 text-center text-sm med-muted">${noResults}</p>`;
        });

        const rightsModal = document.querySelector('[data-med-rights-modal]');
        document.querySelector('[data-med-rights]')?.addEventListener('click', () => rightsModal?.removeAttribute('hidden'));
        document.querySelector('[data-med-rights-close]')?.addEventListener('click', () => rightsModal?.setAttribute('hidden', ''));
        rightsModal?.addEventListener('click', (event) => {
          if (event.target === rightsModal) rightsModal.setAttribute('hidden', '');
        });

        const favorites = new Set(JSON.parse(localStorage.getItem('medrese-favorites') || '[]'));
        document.querySelectorAll('[data-med-favorite]').forEach((button) => {
          const id = button.dataset.medFavorite;
          const sync = () => {
            const saved = favorites.has(id);
            button.dataset.saved = String(saved);
            button.setAttribute('aria-pressed', String(saved));
            const label = button.querySelector('[data-favorite-label]');
            if (label) label.textContent = saved ? button.dataset.savedLabel : button.dataset.saveLabel;
          };
          sync();
          button.addEventListener('click', () => {
            favorites.has(id) ? favorites.delete(id) : favorites.add(id);
            localStorage.setItem('medrese-favorites', JSON.stringify([...favorites]));
            sync();
          });
        });

        document.querySelectorAll('[data-demo-form]').forEach((form) => {
          form.addEventListener('submit', (event) => {
            event.preventDefault();
            const success = form.querySelector('[data-demo-success]');
            success?.removeAttribute('hidden');
            form.querySelector('input')?.setAttribute('disabled', '');
          });
        });

        const aiForm = document.querySelector('[data-ai-form]');
        aiForm?.addEventListener('submit', (event) => {
          event.preventDefault();
          document.querySelector('[data-ai-answer]')?.removeAttribute('hidden');
        });
      })();
    </script>
  </body>
</html>
