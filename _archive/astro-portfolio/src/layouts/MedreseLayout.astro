<style is:global>
  :root {
    --m-bg: #f4f0e7;
    --m-surface: #fffdf8;
    --m-surface-raised: #ffffff;
    --m-text: #17342b;
    --m-muted: #68766f;
    --m-line: rgba(23, 52, 43, 0.12);
    --m-primary: #123f33;
    --m-primary-soft: #dce9e1;
    --m-accent: #bd8b35;
    --m-accent-soft: #f2e7cc;
    --m-hero: #0d332a;
    --m-hero-text: #fffdf6;
    --m-shadow: 0 24px 70px rgba(34, 51, 44, 0.1);
  }

  html[data-medrese-theme='dark'] {
    --m-bg: #0b1714;
    --m-surface: #10231e;
    --m-surface-raised: #142a24;
    --m-text: #eef4ef;
    --m-muted: #9cafA6;
    --m-line: rgba(224, 237, 229, 0.12);
    --m-primary: #dce9e1;
    --m-primary-soft: #18352d;
    --m-accent: #d5ad63;
    --m-accent-soft: #30291b;
    --m-hero: #081c17;
    --m-hero-text: #fffdf6;
    --m-shadow: 0 24px 70px rgba(0, 0, 0, 0.25);
    color-scheme: dark;
  }

  html {
    scroll-behavior: smooth;
  }

  .medrese-body {
    min-height: 100vh;
    margin: 0;
    overflow-x: hidden;
    background: var(--m-bg);
    color: var(--m-text);
    font-family: 'DM Sans', system-ui, sans-serif;
    transition: background 180ms ease, color 180ms ease;
  }

  .medrese-shell {
    width: min(1180px, calc(100% - 2rem));
    margin-inline: auto;
  }

  .medrese-header {
    position: sticky;
    top: 0;
    z-index: 80;
    border-bottom: 1px solid var(--m-line);
    background: color-mix(in srgb, var(--m-surface) 88%, transparent);
    backdrop-filter: blur(18px);
  }

  .header-inner {
    min-height: 76px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
    color: var(--m-text);
  }

  .brand > span:last-child {
    display: grid;
  }

  .brand strong {
    font-family: 'Lora', Georgia, serif;
    font-size: 1.08rem;
    line-height: 1.1;
  }

  .brand small {
    margin-top: 0.18rem;
    color: var(--m-muted);
    font-size: 0.58rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
