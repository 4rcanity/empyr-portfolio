---
import type { Lang } from '../../i18n/ui';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const copy =
  lang === 'nl'
    ? {
        eyebrow: 'Welkom bij Empyr',
        title: 'Wat wil je ontdekken?',
        subtitle: 'Kies een discipline en stap binnen in het werk.',
        webTitle: 'Webdesign',
        webBody: 'Snelle, onderscheidende websites die lokale merken vooruithelpen.',
        webCta: 'Bekijk webprojecten',
        gameTitle: 'Game development',
        gameBody: 'Interactieve werelden, prototypes en ervaringen. Binnenkort meer.',
        gameCta: 'Bekijk wat eraan komt',
        available: 'Beschikbaar',
        wip: 'In ontwikkeling',
      }
    : {
        eyebrow: 'Welcome to Empyr',
        title: 'What would you like to explore?',
        subtitle: 'Choose a discipline and step into the work.',
        webTitle: 'Web design',
        webBody: 'Fast, distinctive websites that move local brands forward.',
        webCta: 'Explore web projects',
        gameTitle: 'Game development',
        gameBody: 'Interactive worlds, prototypes and experiences. More soon.',
        gameCta: 'See what is coming',
        available: 'Available',
        wip: 'In development',
      };
---

<div
  class="portfolio-gate fixed inset-0 z-[100] flex items-center justify-center overflow-y-auto bg-[#090909]/95 px-4 py-8 backdrop-blur-xl"
  data-portfolio-gate
  role="dialog"
  aria-modal="true"
  aria-labelledby="portfolio-gate-title"
>
  <div class="gate-orb gate-orb-one"></div>
  <div class="gate-orb gate-orb-two"></div>

  <div class="relative w-full max-w-5xl">
    <div class="mb-8 text-center">
      <img
        src="/images/empyr-logo.png"
        alt=""
        class="mx-auto h-14 w-14 rounded-2xl object-cover shadow-2xl shadow-orange-500/20"
        width="56"
        height="56"
      />
      <p class="mt-5 text-xs font-bold uppercase tracking-[0.32em] text-orange-400">{copy.eyebrow}</p>
      <h2 id="portfolio-gate-title" class="mt-3 text-3xl font-semibold tracking-[-0.04em] text-white sm:text-5xl">
        {copy.title}
      </h2>
      <p class="mx-auto mt-3 max-w-xl text-sm leading-6 text-stone-400 sm:text-base">{copy.subtitle}</p>
    </div>

    <div class="grid gap-4 md:grid-cols-2">
      <a
        href="#work"
        class="gate-card group relative overflow-hidden rounded-[2rem] border border-white/10 bg-white/[0.06] p-7 text-left transition duration-500 hover:-translate-y-1 hover:border-orange-400/50 hover:bg-white/[0.09] sm:p-9"
        data-portfolio-choice="web"
      >
        <div class="absolute -right-12 -top-12 h-44 w-44 rounded-full bg-orange-500/20 blur-3xl transition duration-500 group-hover:bg-orange-500/30"></div>
        <div class="relative">
          <div class="flex items-center justify-between gap-4">
            <span class="flex h-12 w-12 items-center justify-center rounded-2xl bg-orange-500 text-white shadow-lg shadow-orange-500/20">
              <svg viewBox="0 0 24 24" fill="none" class="h-6 w-6" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
                <rect x="3" y="4" width="18" height="14" rx="2"></rect>
                <path d="M3 8h18M8 21h8M12 18v3"></path>
              </svg>
            </span>
            <span class="rounded-full border border-emerald-400/20 bg-emerald-400/10 px-3 py-1 text-[11px] font-bold uppercase tracking-wider text-emerald-300">
              {copy.available}
            </span>
          </div>
          <h3 class="mt-10 text-2xl font-semibold tracking-tight text-white sm:text-3xl">{copy.webTitle}</h3>
          <p class="mt-3 max-w-sm text-sm leading-6 text-stone-400">{copy.webBody}</p>
          <span class="mt-8 inline-flex items-center gap-2 text-sm font-semibold text-orange-300">
            {copy.webCta}
            <span class="transition-transform duration-300 group-hover:translate-x-1" aria-hidden="true">→</span>
          </span>
        </div>
      </a>

      <a
        href={`/${lang}/games`}
        class="gate-card group relative overflow-hidden rounded-[2rem] border border-white/10 bg-white/[0.04] p-7 text-left transition duration-500 hover:-translate-y-1 hover:border-violet-400/50 hover:bg-white/[0.08] sm:p-9"
        data-portfolio-choice="games"
      >
        <div class="absolute -bottom-14 -right-12 h-48 w-48 rounded-full bg-violet-500/20 blur-3xl transition duration-500 group-hover:bg-violet-500/30"></div>
        <div class="relative">
          <div class="flex items-center justify-between gap-4">
            <span class="flex h-12 w-12 items-center justify-center rounded-2xl bg-violet-500 text-white shadow-lg shadow-violet-500/20">
              <svg viewBox="0 0 24 24" fill="none" class="h-6 w-6" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
                <path d="M8.5 8h7a5.5 5.5 0 0 1 5.24 7.18l-.76 2.37a2 2 0 0 1-3.16.96L14.8 17h-5.6l-2.02 1.51a2 2 0 0 1-3.16-.96l-.76-2.37A5.5 5.5 0 0 1 8.5 8Z"></path>
                <path d="M8 12v3M6.5 13.5h3M16.5 12.5h.01M18 14h.01M9 8l1-3h4l1 3"></path>
              </svg>
            </span>
            <span class="rounded-full border border-violet-400/20 bg-violet-400/10 px-3 py-1 text-[11px] font-bold uppercase tracking-wider text-violet-300">
              {copy.wip}
            </span>
          </div>
          <h3 class="mt-10 text-2xl font-semibold tracking-tight text-white sm:text-3xl">{copy.gameTitle}</h3>
          <p class="mt-3 max-w-sm text-sm leading-6 text-stone-400">{copy.gameBody}</p>
          <span class="mt-8 inline-flex items-center gap-2 text-sm font-semibold text-violet-300">
            {copy.gameCta}
            <span class="transition-transform duration-300 group-hover:translate-x-1" aria-hidden="true">→</span>
          </span>
        </div>
      </a>
    </div>
  </div>
</div>

<script>
  const gate = document.querySelector<HTMLElement>('[data-portfolio-gate]');
  const savedChoice = sessionStorage.getItem('empyr-portfolio-choice');

  if (gate && savedChoice) {
    gate.remove();
  } else if (gate) {
    document.documentElement.style.overflow = 'hidden';
    gate.querySelector<HTMLElement>('[data-portfolio-choice]')?.focus();

    gate.querySelectorAll<HTMLElement>('[data-portfolio-choice]').forEach((choice) => {
      choice.addEventListener('click', () => {
        sessionStorage.setItem('empyr-portfolio-choice', choice.dataset.portfolioChoice ?? 'web');
        document.documentElement.style.overflow = '';
        if (choice.dataset.portfolioChoice === 'web') {
          gate.classList.add('is-leaving');
          window.setTimeout(() => gate.remove(), 360);
        }
      });
    });
  }
</script>

<style>
  .portfolio-gate {
    animation: gate-in 500ms cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  .portfolio-gate.is-leaving {
    animation: gate-out 340ms ease both;
    pointer-events: none;
  }

  .gate-card {
    animation: card-in 600ms 120ms cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  .gate-card + .gate-card {
    animation-delay: 190ms;
  }

  .gate-orb {
    position: absolute;
    border-radius: 999px;
    filter: blur(80px);
    pointer-events: none;
  }

  .gate-orb-one {
    top: -8rem;
    left: -5rem;
    width: 22rem;
    height: 22rem;
    background: rgb(249 115 22 / 0.12);
  }

  .gate-orb-two {
    right: -6rem;
    bottom: -8rem;
    width: 24rem;
    height: 24rem;
    background: rgb(139 92 246 / 0.1);
  }

  @keyframes gate-in {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  @keyframes gate-out {
    to { opacity: 0; transform: scale(1.015); }
  }

  @keyframes card-in {
    from { opacity: 0; transform: translateY(18px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .portfolio-gate,
    .portfolio-gate.is-leaving,
    .gate-card {
      animation: none;
    }
  }
</style>
