---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Footer from './Footer.astro';
import type { SiteConfig, LocalizedContent } from '../../types/site-config';
import type { Lang } from '../../i18n/ui';
import { useTranslations } from '../../i18n/utils';

interface Props {
  config: SiteConfig;
  content: LocalizedContent;
  lang: Lang;
  page: 'impressum' | 'privacy';
}

const { config, content, lang, page } = Astro.props;
const t = useTranslations(lang);
const basePath = `/${lang}/${config.slug}`;
const isImpressum = page === 'impressum';
---

<BaseLayout
  config={config}
  content={content}
  lang={lang}
  title={isImpressum ? t('legal.impressumTitle') : t('legal.privacyTitle')}
  canonicalPath={`${basePath}/${page}`}
>
  <main class="mx-auto max-w-3xl px-4 py-20 sm:px-6">
    <h1 class="text-3xl font-semibold" style="font-family: var(--font-heading); color: var(--color-text);">
      {isImpressum ? t('legal.impressumTitle') : t('legal.privacyTitle')}
    </h1>
    <div class="mt-8 space-y-4 text-base leading-relaxed" style="color: var(--color-muted); font-family: var(--font-body);">
      {isImpressum ? (
        <>
          <p><strong style="color: var(--color-text);">{config.name}</strong></p>
          <p>
            {config.address.street}<br />
            {config.address.postalCode} {config.address.city}<br />
            {config.address.country}
          </p>
          <p>
            {t('nav.contact')}: <a href={`tel:${config.phone.replace(/\s/g, '')}`} style="color: var(--color-accent);">{config.phone}</a><br />
            Email: <a href={`mailto:${config.email}`} style="color: var(--color-accent);">{config.email}</a>
          </p>
          <p>{t('legal.impressumBody')}</p>
        </>
      ) : (
        <>
          <p>
            <strong style="color: var(--color-text);">{config.name}</strong> {t('legal.privacyIntro')}
          </p>
          <h2 class="text-xl font-semibold" style="color: var(--color-text);">{t('legal.dataController')}</h2>
          <p>
            {config.name}<br />
            {config.address.street}, {config.address.postalCode} {config.address.city}<br />
            {config.email}
          </p>
          <h2 class="text-xl font-semibold" style="color: var(--color-text);">{t('legal.hosting')}</h2>
          <p>{t('legal.hostingBody')}</p>
          <h2 class="text-xl font-semibold" style="color: var(--color-text);">{t('legal.rights')}</h2>
          <p>
            {t('legal.rightsBody')} <a href={`mailto:${config.email}`} style="color: var(--color-accent);">{config.email}</a>.
          </p>
        </>
      )}
      <p class="text-sm">{t('legal.demoNotice')}</p>
    </div>
    <p class="mt-8">
      <a href={basePath} style="color: var(--color-accent);">
        {t('legal.backTo')} {config.name}
      </a>
    </p>
  </main>
  <Footer config={config} lang={lang} />
</BaseLayout>
