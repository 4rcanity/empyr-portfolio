---
import type { SiteConfig, LocalizedContent } from '../../types/site-config';
import type { Lang } from '../../i18n/ui';
import { useTranslations } from '../../i18n/utils';

interface Props {
  config: SiteConfig;
  content: LocalizedContent;
  lang: Lang;
  overlay?: boolean;
}

const { config, content, lang, overlay = true } = Astro.props;
const t = useTranslations(lang);
const ctaLabel = content.ctaLabel ?? t('hero.bookTable');
const secondaryLabel = content.secondaryCtaLabel ?? t('hero.viewMenu');
const isBarberhouse = config.theme.variant === 'barberhouse';
---

<section class="relative flex min-h-[88vh] items-end overflow-hidden sm:min-h-[92vh]">
  <img
    src={config.heroImage}
    alt={`${config.name} interior`}
    class="absolute inset-0 h-full w-full object-cover"
    loading="eager"
  />
  {overlay && (
    <div
      class:list={[
        'absolute inset-0',
        isBarberhouse
          ? 'bg-gradient-to-t from-black via-black/70 to-black/30'
          : 'bg-gradient-to-t from-black/85 via-black/40 to-black/10',
      ]}
    >
    </div>
  )}
  {isBarberhouse && (
    <div class="absolute inset-0 bg-black/30"></div>
  )}

  <div class="relative z-10 mx-auto w-full max-w-6xl px-4 pb-16 pt-32 sm:px-6 sm:pb-24">
    <p
      class:list={[
        'mb-4 text-xs font-semibold uppercase tracking-[0.35em] drop-shadow sm:text-sm',
      ]}
      style={
        isBarberhouse
          ? 'background: var(--gradient-gold); -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent; font-family: var(--font-body);'
          : 'color: var(--color-accent); font-family: var(--font-body);'
      }
    >
      {content.tagline}
    </p>
    <h1
      class:list={[
        'max-w-3xl drop-shadow-lg sm:text-6xl lg:text-7xl',
        isBarberhouse
          ? 'text-4xl font-bold uppercase leading-[0.95] sm:text-6xl lg:text-7xl'
          : 'text-4xl font-semibold leading-tight',
      ]}
      style={
        isBarberhouse
          ? 'color: #fff; font-family: var(--font-heading); letter-spacing: 0.02em;'
          : 'color: #fff; font-family: var(--font-heading);'
      }
    >
      {config.name}
    </h1>
    {isBarberhouse && (
      <div class="mt-5 h-0.5 w-24" style="background: var(--gradient-gold);"></div>
    )}
    <p
      class:list={[
        'mt-6 max-w-xl text-white/85 drop-shadow',
        isBarberhouse ? 'text-base leading-relaxed sm:text-lg' : 'text-lg sm:text-xl',
      ]}
      style="font-family: var(--font-body);"
    >
      {content.description}
    </p>
    <div class="mt-8 flex flex-wrap gap-3 sm:gap-4">
      {config.reservationUrl && (
        <a
          href={config.reservationUrl}
          class:list={[
            'inline-flex items-center rounded-full font-semibold transition-transform hover:scale-105',
            isBarberhouse
              ? 'px-7 py-3 text-sm uppercase tracking-wide sm:px-8 sm:text-base gold-fill'
              : 'px-8 py-3 text-base',
          ]}
          style={
            isBarberhouse
              ? 'color: var(--color-on-accent-text); font-family: var(--font-body);'
              : 'background: var(--color-accent); color: var(--color-on-accent-text); font-family: var(--font-body);'
          }
        >
          {ctaLabel}
        </a>
      )}
      <a
        href="#menu"
        class:list={[
          'inline-flex items-center rounded-full font-semibold backdrop-blur-sm transition-colors hover:bg-white/10',
          isBarberhouse
            ? 'px-7 py-3 text-sm uppercase tracking-wide gold-frame text-white sm:px-8 sm:text-base'
            : 'border-2 border-white/70 px-8 py-3 text-base text-white',
        ]}
        style="font-family: var(--font-body);"
      >
        {secondaryLabel}
      </a>
    </div>
  </div>
</section>
