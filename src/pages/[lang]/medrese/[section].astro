<style>
  .section-hero {
    position: relative;
    overflow: hidden;
    background: var(--m-hero);
    color: var(--m-hero-text);
  }

  .section-hero-pattern {
    position: absolute;
    inset: 0;
    opacity: .055;
    background-image:
      linear-gradient(rgba(255,255,255,.8) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,.8) 1px, transparent 1px);
    background-size: 68px 68px;
    mask-image: radial-gradient(circle at 80% 50%, black, transparent 65%);
  }

  .section-hero-inner {
    position: relative;
    min-height: 480px;
    display: grid;
    grid-template-columns: 1fr auto;
    align-content: center;
    gap: 4rem;
    padding-block: 5rem;
  }

  .back-link {
    position: absolute;
    top: 2rem;
    left: 0;
    display: inline-flex;
    align-items: center;
    gap: .5rem;
    color: rgba(255,255,255,.55);
    font-size: .72rem;
    font-weight: 700;
  }

  .section-hero-copy > span {
    color: #d7b978;
    font-size: .67rem;
    font-weight: 800;
    letter-spacing: .18em;
    text-transform: uppercase;
  }

  .section-hero-copy h1 {
    max-width: 760px;
    margin: 1rem 0 0;
    font-family: 'Lora', Georgia, serif;
    font-size: clamp(3rem, 7vw, 5.5rem);
    line-height: 1;
    letter-spacing: -.055em;
  }

  .section-hero-copy p {
    max-width: 650px;
    margin: 1.3rem 0 0;
    color: rgba(255,255,255,.62);
    line-height: 1.7;
  }

  .section-hero-mark {
    display: grid;
    width: 160px;
    height: 200px;
    place-items: center;
    align-self: center;
    border: 1px solid rgba(215,185,120,.25);
    border-radius: 50% 50% 12px 12px;
    color: #d7b978;
    font-family: 'Lora', serif;
    font-size: 2.4rem;
  }

  .content-section {
    padding-block: 5rem 7rem;
    background: var(--m-bg);
  }

  .content-toolbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 2rem;
  }

  .filter-group {
    display: flex;
    flex-wrap: wrap;
    gap: .45rem;
  }

  .filter-group button,
  .saved-filter {
    min-height: 38px;
    padding: .55rem .85rem;
    border: 1px solid var(--m-line);
    border-radius: 999px;
    background: var(--m-surface);
    color: var(--m-muted);
    font: inherit;
    font-size: .68rem;
    font-weight: 700;
    cursor: pointer;
  }

  .filter-group button.is-active,
  .saved-filter[aria-pressed='true'] {
    border-color: var(--m-primary);
    background: var(--m-primary);
    color: var(--m-surface);
  }

  .saved-filter {
    display: inline-flex;
    align-items: center;
    gap: .4rem;
  }

  .saved-filter svg { width: 15px; }

  .lesson-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }

  .lesson-card {
    display: flex;
    min-height: 360px;
    flex-direction: column;
    padding: 1.5rem;
    border: 1px solid var(--m-line);
    border-radius: 24px;
    background: var(--m-surface);
    box-shadow: 0 8px 30px transparent;
    transition: transform 180ms ease, box-shadow 180ms ease;
  }

  .lesson-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--m-shadow);
  }

  .lesson-card.is-saved {
    border-color: color-mix(in srgb, var(--m-accent) 55%, var(--m-line));
  }

  .lesson-card-heading {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .lesson-card-heading > div {
    display: flex;
    align-items: center;
    gap: .6rem;
  }

  .lesson-card-heading div > span {
    color: var(--m-accent);
    font-family: 'Lora', serif;
    font-size: .75rem;
  }

  .lesson-card-heading small {
    padding: .35rem .55rem;
    border-radius: 999px;
    background: var(--m-primary-soft);
    color: var(--m-muted);
    font-size: .58rem;
    font-weight: 700;
  }

  .favorite-button {
    display: grid;
    width: 36px;
    height: 36px;
    place-items: center;
    border: 1px solid var(--m-line);
    border-radius: 50%;
    background: transparent;
    color: var(--m-muted);
    cursor: pointer;
  }

  .favorite-button svg { width: 16px; }
  .favorite-button[aria-pressed='true'] { background: var(--m-accent-soft); color: var(--m-accent); }
  .favorite-button[aria-pressed='true'] svg { fill: currentColor; }

  .lesson-card h2 {
    margin: 2.1rem 0 0;
    font-family: 'Lora', Georgia, serif;
    font-size: 1.45rem;
    line-height: 1.2;
  }

  .lesson-card > p,
  .lesson-preview p {
    margin: .8rem 0 0;
    color: var(--m-muted);
    font-size: .82rem;
    line-height: 1.7;
  }

  .source-line {
    display: grid;
    gap: .2rem;
    margin-top: 1rem;
    padding-left: .7rem;
    border-left: 2px solid var(--m-accent);
  }

  .source-line strong { color: var(--m-accent); font-size: .56rem; text-transform: uppercase; letter-spacing: .12em; }
  .source-line span { color: var(--m-muted); font-size: .65rem; }

  .lesson-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-top: auto;
    padding-top: 1.4rem;
  }

  .lesson-footer > span { color: var(--m-muted); font-size: .65rem; }
  .lesson-footer button { display: inline-flex; gap: .4rem; border: 0; background: transparent; color: var(--m-accent); font: inherit; font-size: .7rem; font-weight: 700; cursor: pointer; }

  .lesson-preview { margin-top: 1rem; }
  .preview-rule { width: 35px; height: 1px; background: var(--m-accent); }
  .lesson-preview small { display: block; margin-top: .8rem; color: var(--m-muted); font-size: .58rem; line-height: 1.5; }

  .rights-notice {
    display: flex;
    align-items: flex-start;
    gap: .8rem;
