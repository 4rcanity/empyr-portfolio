      <div class="section-hero-mark" aria-hidden="true">
        <span>{String(medreseSectionSlugs.indexOf(section.slug) + 1).padStart(2, '0')}</span>
      </div>
    </div>
  </section>

  <section class="content-section">
    <div class="medrese-shell">
      <div class="content-toolbar">
        <div class="filter-group" role="group" aria-label="Filter">
          <button type="button" class="is-active" data-filter="all">All</button>
          {[...new Set(section.items.map((item) => item.tag))].map((tag) => (
            <button type="button" data-filter={tag}>{tag}</button>
          ))}
