---
import MedreseLayout from '../../../layouts/MedreseLayout.astro';
import {
  getMedreseCopy,
  localize,
  medreseItems,
  medreseLanguages,
  medreseSections,
  type MedreseLang,
  type MedreseSection,
} from '../../../data/medrese';

export function getStaticPaths() {
  return medreseLanguages.flatMap((lang) =>
    medreseSections.map((section) => ({
      params: { lang, section: section.id },
      props: { section },
    }))
  );
}

const { lang } = Astro.params as { lang: MedreseLang };
const { section } = Astro.props as { section: MedreseSection };
const copy = getMedreseCopy(lang);
const items = medreseItems.filter((item) => item.section === section.id);
const tags = [...new Set(items.flatMap((item) => item.tags))].slice(0, 8);
const isRightsSensitive = section.id === 'risale' || section.id === 'bibliotheek';
---

<MedreseLayout
  lang={lang}
  title={localize(section.title, lang)}
  description={localize(section.description, lang)}
  path={`/${section.id}`}
>
  <main>
    <section class="relative isolate overflow-hidden border-b med-border">
      <div class="med-grid-pattern pointer-events-none absolute inset-0 -z-20 opacity-70"></div>
      <div class="pointer-events-none absolute right-[-10rem] top-[-12rem] -z-10 h-[30rem] w-[30rem] rounded-full bg-[color:var(--med-accent)]/14 blur-[100px]"></div>
      <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 sm:py-24 lg:px-8">
        <nav class="flex flex-wrap items-center gap-2 text-xs font-semibold med-muted" aria-label="Breadcrumb">
          <a href={`/${lang}/medrese/`} class="hover:med-primary">{copy.siteName}</a>
          <span aria-hidden="true">/</span>
          <span class="med-primary">{localize(section.title, lang)}</span>
        </nav>
        <div class="mt-10 grid gap-10 lg:grid-cols-[1fr_auto] lg:items-end">
          <div>
            <p class="med-kicker">{copy.allSections}</p>
            <h1 class="med-serif mt-4 max-w-4xl text-5xl font-semibold leading-[0.98] tracking-[-0.05em] sm:text-7xl">
              {localize(section.title, lang)}
            </h1>
            <p class="mt-6 max-w-2xl text-base leading-8 med-muted sm:text-lg">{localize(section.description, lang)}</p>
          </div>
          <div class="rounded-2xl border med-border med-surface px-5 py-4">
            <p class="text-[10px] font-bold uppercase tracking-[0.16em] med-muted">
              {lang === 'tr' ? 'İçerik' : lang === 'nl' ? 'Inhoud' : 'Content'}
            </p>
            <p class="med-serif mt-1 text-2xl font-semibold">{items.length} {lang === 'tr' ? 'öğe' : lang === 'nl' ? 'onderwerpen' : 'topics'}</p>
          </div>
        </div>
      </div>
    </section>

    <section class="py-16 sm:py-24">
      <div class="mx-auto grid max-w-7xl gap-10 px-4 sm:px-6 lg:grid-cols-[14rem_1fr] lg:px-8">
        <aside class="lg:sticky lg:top-24 lg:self-start">
          <p class="text-[10px] font-extrabold uppercase tracking-[0.18em] med-muted">{copy.allSections}</p>
          <nav class="mt-4 grid grid-cols-2 gap-1 sm:grid-cols-3 lg:grid-cols-1" aria-label={copy.allSections}>
            {medreseSections.map((navSection) => (
              <a
                href={`/${lang}/medrese/${navSection.id}/`}
                class="rounded-xl px-3 py-2.5 text-xs font-semibold transition"
                style={navSection.id === section.id
                  ? 'background: var(--med-primary); color: var(--med-bg);'
                  : 'color: var(--med-muted);'}
              >
                {localize(navSection.title, lang)}
              </a>
            ))}
          </nav>
        </aside>

        <div>
          {isRightsSensitive && (
            <div class="mb-8 flex items-start gap-4 rounded-2xl border border-[color:var(--med-accent)]/30 bg-[color:var(--med-accent)]/10 p-5">
              <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-[color:var(--med-accent)]/15 med-accent">i</span>
              <div>
                <strong class="text-sm">{copy.rights}</strong>
                <p class="mt-1 text-xs leading-6 med-muted">{copy.rightsBody}</p>
              </div>
            </div>
          )}

          <div class="flex flex-col gap-4 border-b med-border pb-6 sm:flex-row sm:items-center sm:justify-between">
            <div class="flex flex-wrap gap-2" data-med-filters>
              <button type="button" class="rounded-full px-3 py-1.5 text-[10px] font-extrabold uppercase tracking-wider" data-filter="all" aria-pressed="true" style="background: var(--med-primary); color: var(--med-bg);">
                {lang === 'tr' ? 'Tümü' : lang === 'nl' ? 'Alles' : 'All'}
              </button>
              {tags.map((tag) => (
                <button type="button" class="rounded-full border med-border px-3 py-1.5 text-[10px] font-extrabold uppercase tracking-wider med-muted" data-filter={tag} aria-pressed="false">
                  {tag}
                </button>
              ))}
            </div>
            <button type="button" class="med-button-secondary shrink-0" data-med-search-open>
              <svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
                <circle cx="11" cy="11" r="6.5"></circle><path d="m16 16 4 4"></path>
              </svg>
              {copy.search}
            </button>
          </div>

          <div class="mt-8 grid gap-5 md:grid-cols-2" data-med-item-grid>
            {items.map((item, index) => (
              <article
                id={item.id}
                class:list={[
                  'med-card scroll-mt-28 rounded-[1.7rem] p-6 sm:p-7',
                  index === 0 && 'md:col-span-2',
                ]}
                data-med-item
                data-tags={item.tags.join(' ')}
              >
                <div class="flex items-start justify-between gap-5">
                  <div>
                    <p class="text-[10px] font-extrabold uppercase tracking-[0.16em] med-accent">{localize(item.meta, lang)}</p>
                    <h2 class:list={['med-serif mt-3 font-semibold tracking-tight', index === 0 ? 'text-3xl sm:text-4xl' : 'text-2xl']}>
                      {localize(item.title, lang)}
                    </h2>
                  </div>
                  <button
                    type="button"
                    class="med-favorite flex h-10 shrink-0 items-center gap-2 rounded-full border med-border px-3 text-xs font-bold"
                    data-med-favorite={item.id}
                    data-save-label={copy.favorite}
                    data-saved-label={copy.saved}
                    aria-pressed="false"
                  >
                    <span aria-hidden="true">♡</span>
                    <span class="hidden sm:inline" data-favorite-label>{copy.favorite}</span>
                  </button>
                </div>
                <p class:list={['mt-4 leading-7 med-muted', index === 0 ? 'max-w-3xl text-base' : 'text-sm']}>
                  {localize(item.summary, lang)}
                </p>
                <div class="mt-6 flex flex-wrap items-center gap-2">
                  {item.tags.map((tag) => (
                    <span class="rounded-full med-surface-soft px-2.5 py-1 text-[9px] font-bold uppercase tracking-wider med-muted">{tag}</span>
                  ))}
                </div>
                {item.source && (
                  <div class="mt-6 border-t med-border pt-4 text-[10px] leading-5 med-muted">
                    <span class="font-extrabold uppercase tracking-wider med-primary">Source</span> · {item.source}
                  </div>
                )}
                {item.availability === 'permission' && (
                  <button type="button" class="mt-6 cursor-not-allowed rounded-full border med-border px-4 py-2 text-xs font-bold med-muted" disabled>
                    {lang === 'tr' ? 'İzinle kullanılabilir' : lang === 'nl' ? 'Beschikbaar met toestemming' : 'Available with permission'}
                  </button>
                )}
              </article>
            ))}
          </div>

          <div class="mt-14 overflow-hidden rounded-[2rem] bg-[color:var(--med-primary-strong)] p-8 text-[#f7f2e8] sm:p-10">
            <div class="grid gap-8 sm:grid-cols-[1fr_auto] sm:items-center">
              <div>
                <p class="text-[10px] font-extrabold uppercase tracking-[0.2em] text-[#dfc176]">{copy.newsletterTitle}</p>
                <h2 class="med-serif mt-3 text-3xl font-semibold">
                  {section.id === 'medrese'
                    ? (lang === 'tr' ? 'Bir gruba katılın' : lang === 'nl' ? 'Sluit aan bij een groep' : 'Join a group')
                    : (lang === 'tr' ? 'Öğrenmeye devam edin' : lang === 'nl' ? 'Blijf verder leren' : 'Keep learning')}
                </h2>
                <p class="mt-3 max-w-2xl text-sm leading-7 text-[#a8c9bd]">{copy.newsletterBody}</p>
              </div>
              <a href="mailto:business@empyr-portfolio.com?subject=Medrese%20demo" class="inline-flex rounded-full bg-[#dfc176] px-6 py-3.5 text-sm font-extrabold text-[#12382d]">
                Contact →
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <script>
    const filterContainer = document.querySelector<HTMLElement>('[data-med-filters]');
    const cards = document.querySelectorAll<HTMLElement>('[data-med-item]');

    filterContainer?.addEventListener('click', (event) => {
      const button = (event.target as HTMLElement).closest<HTMLButtonElement>('[data-filter]');
      if (!button) return;
      const filter = button.dataset.filter ?? 'all';
      filterContainer.querySelectorAll<HTMLButtonElement>('[data-filter]').forEach((candidate) => {
        const active = candidate === button;
        candidate.setAttribute('aria-pressed', String(active));
        candidate.style.background = active ? 'var(--med-primary)' : '';
        candidate.style.color = active ? 'var(--med-bg)' : 'var(--med-muted)';
      });
      cards.forEach((card) => {
        const visible = filter === 'all' || (card.dataset.tags ?? '').split(' ').includes(filter);
        card.toggleAttribute('hidden', !visible);
      });
    });
  </script>
</MedreseLayout>
{/*
---
