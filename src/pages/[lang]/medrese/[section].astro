          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" aria-hidden="true"><path d="M6 4.5A1.5 1.5 0 0 1 7.5 3h9A1.5 1.5 0 0 1 18 4.5V21l-6-3.8L6 21V4.5Z"></path></svg>
          {copy.page.saved}
        </button>
      </div>

      <div class="lesson-grid" data-lesson-grid>
        {section.items.map((item, index) => (
          <article id={item.id} class="lesson-card" data-lesson data-tag={item.tag} data-id={`${section.slug}:${item.id}`}>
            <div class="lesson-card-heading">
              <div>
                <span>{String(index + 1).padStart(2, '0')}</span>
                <small>{item.tag}</small>
              </div>
              <button type="button" class="favorite-button" data-favorite aria-label={copy.page.save} aria-pressed="false">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" aria-hidden="true"><path d="M6 4.5A1.5 1.5 0 0 1 7.5 3h9A1.5 1.5 0 0 1 18 4.5V21l-6-3.8L6 21V4.5Z"></path></svg>
              </button>
            </div>
            <h2>{item.title}</h2>
            <p>{item.summary}</p>
            {item.source && <div class="source-line"><strong>{copy.page.source}</strong><span>{item.source}</span></div>}
            <div class="lesson-footer">
              <span>{item.meta}</span>
              <button type="button" data-preview>{copy.page.read}<span aria-hidden="true">→</span></button>
            </div>
            <div class="lesson-preview" data-preview-panel hidden>
              <div class="preview-rule"></div>
              <p>{item.summary}</p>
              <small>{copy.page.rights}</small>
            </div>
          </article>
        ))}
      </div>
      <p class="empty-message" data-empty hidden>{copy.page.empty}</p>

      <aside class="rights-notice">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><path d="M12 3 4.5 6v5.5c0 4.6 3.2 7.8 7.5 9.5 4.3-1.7 7.5-4.9 7.5-9.5V6L12 3Z"></path><path d="M9 12.2 11.1 14 15 9.8"></path></svg>
        <p>{copy.page.rights}</p>
      </aside>
    </div>
  </section>

  <script>
    const storageKey = 'medrese-favorites';
    const getFavorites = (): string[] => {
      try {
        return JSON.parse(localStorage.getItem(storageKey) ?? '[]');
      } catch {
        return [];
      }
    };
    const saveFavorites = (favorites: string[]) => localStorage.setItem(storageKey, JSON.stringify(favorites));
    const cards = [...document.querySelectorAll<HTMLElement>('[data-lesson]')];
    let activeFilter = 'all';
    let savedOnly = false;

    function syncFavorites() {
      const favorites = getFavorites();
      cards.forEach((card) => {
        const saved = favorites.includes(card.dataset.id ?? '');
        const button = card.querySelector<HTMLButtonElement>('[data-favorite]');
        button?.setAttribute('aria-pressed', String(saved));
        card.classList.toggle('is-saved', saved);
      });
    }

    function applyFilters() {
      const favorites = getFavorites();
      let visible = 0;
      cards.forEach((card) => {
        const matchesTag = activeFilter === 'all' || card.dataset.tag === activeFilter;
        const matchesSaved = !savedOnly || favorites.includes(card.dataset.id ?? '');
        const show = matchesTag && matchesSaved;
        card.hidden = !show;
        if (show) visible += 1;
      });
      const empty = document.querySelector<HTMLElement>('[data-empty]');
      if (empty) empty.hidden = visible > 0;
    }

    document.querySelectorAll<HTMLButtonElement>('[data-filter]').forEach((button) => {
      button.addEventListener('click', () => {
        activeFilter = button.dataset.filter ?? 'all';
        document.querySelectorAll('[data-filter]').forEach((item) => item.classList.remove('is-active'));
        button.classList.add('is-active');
        applyFilters();
      });
    });

    const savedFilter = document.querySelector<HTMLButtonElement>('[data-saved-filter]');
    savedFilter?.addEventListener('click', () => {
      savedOnly = !savedOnly;
      savedFilter.setAttribute('aria-pressed', String(savedOnly));
      applyFilters();
    });

    document.querySelectorAll<HTMLButtonElement>('[data-favorite]').forEach((button) => {
      button.addEventListener('click', () => {
        const card = button.closest<HTMLElement>('[data-lesson]');
        const id = card?.dataset.id;
        if (!id) return;
        const favorites = getFavorites();
        const next = favorites.includes(id) ? favorites.filter((entry) => entry !== id) : [...favorites, id];
        saveFavorites(next);
        syncFavorites();
        applyFilters();
      });
    });

    document.querySelectorAll<HTMLButtonElement>('[data-preview]').forEach((button) => {
      button.addEventListener('click', () => {
        const panel = button.closest('[data-lesson]')?.querySelector<HTMLElement>('[data-preview-panel]');
        if (panel) panel.hidden = !panel.hidden;
      });
    });

    syncFavorites();
  </script>
</MedreseLayout>
