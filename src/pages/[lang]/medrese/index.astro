---
import MedreseLayout from '../../../layouts/MedreseLayout.astro';
import {
  getMedreseCopy,
  localize,
  medreseItems,
  medreseLanguages,
  medreseSections,
  type MedreseLang,
} from '../../../data/medrese';

export function getStaticPaths() {
  return medreseLanguages.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: MedreseLang };
const copy = getMedreseCopy(lang);
const featuredSections = medreseSections.filter((section) => section.featured);
const latestItems = [
  medreseItems.find((item) => item.id === 'digital-balance'),
  medreseItems.find((item) => item.id === 'event-lecture'),
  medreseItems.find((item) => item.id === 'media-risale'),
].filter(Boolean);
const weeklyItems = medreseItems.filter((item) => item.section === 'medrese');

const iconPaths: Record<string, string> = {
  'book-open': 'M4 5.5c3.3 0 6 .7 8 2.4 2-1.7 4.7-2.4 8-2.4v13c-3.4 0-6 .7-8 2.5-2-1.8-4.6-2.5-8-2.5v-13Zm8 2.4V21',
  compass: 'm15.5 8.5-2.2 4.8-4.8 2.2 2.2-4.8 4.8-2.2ZM12 3a9 9 0 1 0 0 18 9 9 0 0 0 0-18Z',
  sparkles: 'm12 3 1.4 4.1L17.5 8.5l-4.1 1.4L12 14l-1.4-4.1-4.1-1.4 4.1-1.4L12 3Zm6 10 .9 2.6 2.6.9-2.6.9L18 20l-.9-2.6-2.6-.9 2.6-.9L18 13Z',
  users: 'M16 20v-1.5a4.5 4.5 0 0 0-4.5-4.5h-3A4.5 4.5 0 0 0 4 18.5V20M10 10a3.5 3.5 0 1 0 0-7 3.5 3.5 0 0 0 0 7Zm7-1a3 3 0 0 1 0 6c1.8.4 3 1.8 3 3.5V20',
};
---

<MedreseLayout
  lang={lang}
  title={copy.siteName}
  description={copy.heroBody}
>
  <main>
    <section class="relative isolate overflow-hidden">
      <div class="med-grid-pattern pointer-events-none absolute inset-0 -z-20"></div>
      <div class="pointer-events-none absolute -right-32 -top-32 -z-10 h-[34rem] w-[34rem] rounded-full bg-[color:var(--med-accent)]/15 blur-[100px]"></div>
      <div class="pointer-events-none absolute -left-40 bottom-[-18rem] -z-10 h-[36rem] w-[36rem] rounded-full bg-[color:var(--med-primary)]/15 blur-[110px]"></div>

      <div class="mx-auto grid min-h-[76vh] max-w-7xl items-center gap-14 px-4 py-20 sm:px-6 lg:grid-cols-[1.05fr_.95fr] lg:px-8">
        <div>
          <p class="med-kicker">{copy.heroEyebrow}</p>
          <h1 class="med-serif mt-5 max-w-3xl text-5xl font-semibold leading-[0.96] tracking-[-0.055em] sm:text-7xl lg:text-[5.5rem]">
            {copy.heroTitle}
          </h1>
          <p class="mt-7 max-w-2xl text-base leading-8 med-muted sm:text-lg">{copy.heroBody}</p>
          <div class="mt-9 flex flex-col gap-3 sm:flex-row">
            <a href="#leren" class="med-button-primary">{copy.startLearning}<span aria-hidden="true">↓</span></a>
            <a href={`/${lang}/medrese/risale/`} class="med-button-secondary">{copy.discoverRisale}<span aria-hidden="true">→</span></a>
          </div>
          <div class="mt-10 flex flex-wrap gap-5 border-t med-border pt-6 text-xs font-bold med-muted">
            <span>NL · TR · EN</span>
            <span>10 {lang === 'tr' ? 'bölüm' : lang === 'nl' ? 'onderdelen' : 'sections'}</span>
            <span>{lang === 'tr' ? 'Kaynak odaklı' : lang === 'nl' ? 'Bronbewust' : 'Source-aware'}</span>
          </div>
        </div>

        <div class="relative">
          <div class="absolute -inset-10 rounded-full bg-[color:var(--med-primary)]/10 blur-3xl"></div>
          <div class="relative overflow-hidden rounded-[2.2rem] border med-border med-surface p-3 shadow-[var(--med-shadow)]">
            <div class="relative overflow-hidden rounded-[1.7rem] bg-[color:var(--med-primary-strong)] p-6 text-[#f7f2e8] sm:p-8">
              <div class="absolute -right-10 -top-10 h-44 w-44 rounded-full border border-white/10"></div>
              <div class="absolute -right-4 -top-4 h-32 w-32 rounded-full border border-white/10"></div>
              <div class="relative flex items-center justify-between">
                <p class="text-[10px] font-extrabold uppercase tracking-[0.24em] text-[#e2c579]">{copy.daily}</p>
                <span class="rounded-full border border-white/15 bg-white/5 px-3 py-1 text-[9px] font-bold uppercase tracking-wider">14 · 07 · 2026</span>
              </div>
              <div class="relative mt-10">
                <p class="text-[10px] font-bold uppercase tracking-[0.18em] text-[#a8c9bd]">{copy.ayahLabel}</p>
                <blockquote class="med-serif mt-3 text-2xl font-semibold leading-snug sm:text-3xl">“{copy.ayahText}”</blockquote>
                <p class="mt-4 text-xs text-[#a8c9bd]">{copy.ayahSource}</p>
              </div>
            </div>

            <div class="p-6 sm:p-7">
              <p class="text-[10px] font-extrabold uppercase tracking-[0.18em] med-accent">{copy.hadithLabel}</p>
              <p class="med-serif mt-3 text-xl font-semibold leading-relaxed">“{copy.hadithText}”</p>
              <p class="mt-3 text-xs med-muted">{copy.hadithSource}</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section id="leren" class="border-y med-border med-surface py-24 sm:py-28">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="flex flex-col gap-5 md:flex-row md:items-end md:justify-between">
          <div>
            <p class="med-kicker">{copy.allSections}</p>
            <h2 class="med-serif mt-3 text-4xl font-semibold tracking-tight sm:text-5xl">{copy.explore}</h2>
            <p class="mt-4 max-w-2xl text-sm leading-7 med-muted">{copy.exploreBody}</p>
          </div>
          <button type="button" class="med-button-secondary" data-med-search-open>
            <svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
              <circle cx="11" cy="11" r="6.5"></circle><path d="m16 16 4 4"></path>
            </svg>
            {copy.search}
          </button>
        </div>

        <div class="mt-12 grid gap-5 md:grid-cols-2 lg:grid-cols-4">
          {featuredSections.map((section, index) => (
            <a
              href={`/${lang}/medrese/${section.id}/`}
              class:list={[
                'med-card group relative overflow-hidden rounded-[1.8rem] p-6 sm:p-7',
                index === 0 && 'lg:col-span-2 lg:row-span-2 lg:p-9',
              ]}
            >
              <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-[color:var(--med-primary)]/10 med-primary">
                <svg viewBox="0 0 24 24" class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
                  <path d={iconPaths[section.icon]} stroke-linecap="round" stroke-linejoin="round"></path>
                </svg>
              </div>
              <h3 class:list={['med-serif mt-8 font-semibold tracking-tight', index === 0 ? 'text-3xl sm:text-4xl' : 'text-2xl']}>
                {localize(section.title, lang)}
              </h3>
              <p class:list={['mt-3 leading-7 med-muted', index === 0 ? 'max-w-lg text-base' : 'text-sm']}>
                {localize(section.description, lang)}
              </p>
              <span class="mt-8 inline-flex items-center gap-2 text-xs font-extrabold med-primary">
                {copy.viewSection}<span class="transition-transform group-hover:translate-x-1" aria-hidden="true">→</span>
              </span>
              {index === 0 && (
                <div class="pointer-events-none absolute -bottom-20 -right-16 h-64 w-64 rounded-full bg-[color:var(--med-accent)]/15 blur-3xl"></div>
              )}
            </a>
          ))}
        </div>

        <div class="mt-5 grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
          {medreseSections.filter((section) => !section.featured).map((section) => (
            <a href={`/${lang}/medrese/${section.id}/`} class="group flex items-center gap-4 rounded-2xl border med-border p-4 transition hover:bg-[color:var(--med-surface-soft)]">
              <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl med-surface-soft text-sm font-extrabold med-primary">
                {localize(section.title, lang).charAt(0)}
              </span>
              <span class="min-w-0">
                <strong class="block truncate text-sm">{localize(section.title, lang)}</strong>
                <span class="mt-0.5 block truncate text-xs med-muted">{localize(section.description, lang)}</span>
              </span>
              <span class="ml-auto med-muted transition group-hover:translate-x-1" aria-hidden="true">→</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="py-24 sm:py-28">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="grid gap-8 lg:grid-cols-[1.15fr_.85fr]">
          <div>
            <p class="med-kicker">{copy.latest}</p>
            <h2 class="med-serif mt-3 text-4xl font-semibold">{copy.latestBody}</h2>
            <div class="mt-9 grid gap-5 sm:grid-cols-2">
              {latestItems.map((item, index) => item && (
                <article class:list={['med-card rounded-[1.7rem] p-6', index === 0 && 'sm:col-span-2']}>
                  <div class="flex items-start justify-between gap-4">
                    <div>
                      <p class="text-[10px] font-extrabold uppercase tracking-[0.16em] med-accent">{localize(item.meta, lang)}</p>
                      <h3 class="med-serif mt-3 text-2xl font-semibold">{localize(item.title, lang)}</h3>
                    </div>
                    <button
                      type="button"
                      class="med-favorite flex h-10 shrink-0 items-center gap-2 rounded-full border med-border px-3 text-xs font-bold"
                      data-med-favorite={item.id}
                      data-save-label={copy.favorite}
                      data-saved-label={copy.saved}
                      aria-pressed="false"
                    >
                      <span aria-hidden="true">♡</span><span class="hidden sm:inline" data-favorite-label>{copy.favorite}</span>
                    </button>
                  </div>
                  <p class="mt-4 text-sm leading-7 med-muted">{localize(item.summary, lang)}</p>
                  <a href={`/${lang}/medrese/${item.section}/#${item.id}`} class="mt-6 inline-flex items-center gap-2 text-xs font-extrabold med-primary">
                    {copy.readMore}<span aria-hidden="true">→</span>
                  </a>
                </article>
              ))}
            </div>
          </div>

          <aside class="space-y-5">
            <div class="overflow-hidden rounded-[1.8rem] border med-border bg-[color:var(--med-primary-strong)] p-7 text-[#f7f2e8] shadow-[var(--med-shadow)]">
              <div class="flex items-center justify-between">
                <div>
                  <p class="text-[10px] font-extrabold uppercase tracking-[0.2em] text-[#dfc176]">{copy.prayerTitle}</p>
                  <p class="mt-2 text-xs text-[#a8c9bd]">{copy.prayerCity}</p>
                </div>
                <svg viewBox="0 0 24 24" class="h-6 w-6 text-[#dfc176]" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                  <path d="M20 15.2A8.5 8.5 0 1 1 8.8 4a7 7 0 0 0 11.2 11.2Z"></path>
                </svg>
              </div>
              <div class="mt-7 grid grid-cols-5 gap-2">
                {copy.prayers.map((prayer, index) => (
                  <div class:list={['rounded-xl px-1 py-3 text-center', index === 3 ? 'bg-white/10 ring-1 ring-[#dfc176]/40' : 'bg-white/[0.04]']}>
                    <p class="text-[9px] font-bold text-[#a8c9bd]">{prayer}</p>
                    <p class="mt-2 text-xs font-extrabold">{copy.times[index]}</p>
                  </div>
                ))}
              </div>
              <p class="mt-4 text-[10px] leading-5 text-[#a8c9bd]">Demo times only · verify with your local mosque.</p>
            </div>

            <div class="med-card rounded-[1.8rem] p-7">
              <p class="med-kicker">{copy.scheduleTitle}</p>
              <div class="mt-5 space-y-5">
                {weeklyItems.map((item) => (
                  <a href={`/${lang}/medrese/medrese/#${item.id}`} class="flex items-start gap-4">
                    <span class="mt-1 h-2 w-2 shrink-0 rounded-full bg-[color:var(--med-accent)]"></span>
                    <span>
                      <strong class="block text-sm">{localize(item.title, lang)}</strong>
                      <span class="mt-1 block text-xs med-muted">{localize(item.meta, lang)}</span>
                    </span>
                  </a>
                ))}
              </div>
            </div>
          </aside>
        </div>
      </div>
    </section>

    <section class="border-y med-border med-surface py-24">
      <div class="mx-auto grid max-w-7xl gap-8 px-4 sm:px-6 lg:grid-cols-2 lg:px-8">
        <div class="relative overflow-hidden rounded-[2rem] bg-[color:var(--med-primary-strong)] p-7 text-[#f7f2e8] sm:p-9">
          <div class="pointer-events-none absolute -right-20 -top-20 h-64 w-64 rounded-full border border-white/10"></div>
          <p class="text-[10px] font-extrabold uppercase tracking-[0.2em] text-[#dfc176]">Medrese AI</p>
          <h2 class="med-serif mt-3 text-3xl font-semibold">{copy.aiTitle}</h2>
          <p class="mt-3 max-w-lg text-sm leading-7 text-[#a8c9bd]">{copy.aiBody}</p>
          <form class="relative mt-7" data-ai-form>
            <input class="w-full rounded-2xl border border-white/10 bg-white/10 py-4 pl-4 pr-28 text-sm text-white outline-none placeholder:text-[#a8c9bd]" placeholder={copy.aiPlaceholder} />
            <button class="absolute bottom-2 right-2 top-2 rounded-xl bg-[#dfc176] px-4 text-xs font-extrabold text-[#12382d]" type="submit">{copy.aiAsk}</button>
          </form>
          <div class="mt-5 rounded-2xl border border-white/10 bg-black/10 p-5" data-ai-answer hidden>
            <p class="text-sm leading-7">{copy.aiAnswer}</p>
            <p class="mt-4 text-[10px] font-bold uppercase tracking-wider text-[#dfc176]">{copy.aiSources}</p>
          </div>
          <p class="mt-4 text-[10px] leading-5 text-[#a8c9bd]">{copy.aiDisclaimer}</p>
        </div>

        <div class="med-card flex flex-col justify-center rounded-[2rem] p-7 sm:p-9">
          <p class="med-kicker">Newsletter</p>
          <h2 class="med-serif mt-3 text-3xl font-semibold">{copy.newsletterTitle}</h2>
          <p class="mt-3 text-sm leading-7 med-muted">{copy.newsletterBody}</p>
          <form class="mt-7 flex flex-col gap-3 sm:flex-row" data-demo-form>
            <input class="med-input flex-1" type="email" required placeholder={copy.emailPlaceholder} />
            <button class="med-button-primary shrink-0" type="submit">{copy.subscribe}</button>
            <p class="text-xs med-primary sm:col-span-2" data-demo-success hidden>{copy.demoSuccess}</p>
          </form>
        </div>
      </div>
    </section>
  </main>
</MedreseLayout>
{/*
---
import MedreseLayout from '../../../layouts/MedreseLayout.astro';
import {
  isMedreseLang,
  medreseCopy,
  medreseLanguages,
  medreseSections,
  type MedreseLang,
} from '../../../data/medrese';

export function getStaticPaths() {
  return medreseLanguages.map((lang) => ({ params: { lang } }));
}

const rawLang = Astro.params.lang;
const lang: MedreseLang = isMedreseLang(rawLang) ? rawLang : 'nl';
const copy = medreseCopy[lang];
const sections = medreseSections[lang];
---

<MedreseLayout lang={lang}>
  <section class="medrese-hero">
    <div class="hero-pattern" aria-hidden="true"></div>
    <div class="hero-glow" aria-hidden="true"></div>
    <div class="medrese-shell hero-grid">
      <div class="hero-copy">
        <p class="hero-eyebrow"><span></span>{copy.hero.eyebrow}</p>
        <h1>{copy.hero.title} <em>{copy.hero.accent}</em></h1>
        <p class="hero-body">{copy.hero.body}</p>
        <div class="hero-actions">
          <a href="#learn" class="medrese-button primary">{copy.hero.primary}<span aria-hidden="true">↓</span></a>
          <a href="#schedule" class="medrese-button secondary">{copy.hero.secondary}</a>
        </div>
        <div class="hero-languages">
          <span>NL</span><i></i><span>TR</span><i></i><span>EN</span>
        </div>
      </div>

      <div class="hero-art" aria-hidden="true">
        <div class="arch arch-outer">
          <div class="arch arch-middle">
            <div class="arch arch-inner">
              <span class="arabic">اقْرَأْ</span>
              <small>Lees · Oku · Read</small>
            </div>
          </div>
        </div>
        <div class="art-orbit orbit-one"></div>
        <div class="art-orbit orbit-two"></div>
      </div>
    </div>
  </section>

  <section class="daily-band">
    <div class="medrese-shell">
      <div class="daily-label"><span></span>{copy.daily.label}</div>
      <div class="daily-grid">
        <article>
          <span class="daily-number">01</span>
          <div>
            <h2>{copy.daily.ayahTitle}</h2>
            <p>{copy.daily.ayahText}</p>
            <small>{copy.daily.ayahSource}</small>
          </div>
        </article>
        <article>
          <span class="daily-number">02</span>
          <div>
            <h2>{copy.daily.hadithTitle}</h2>
            <p>{copy.daily.hadithText}</p>
            <small>{copy.daily.hadithSource}</small>
          </div>
        </article>
      </div>
      <p class="daily-disclaimer">{copy.daily.disclaimer}</p>
    </div>
  </section>

  <section id="learn" class="section-block learning-section">
    <div class="medrese-shell">
      <div class="section-heading">
        <span class="section-kicker">{copy.sections.eyebrow}</span>
        <h2>{copy.sections.title}</h2>
        <p>{copy.sections.body}</p>
      </div>

      <div class="section-card-grid">
        {sections.map((section, index) => (
          <a href={`/${lang}/medrese/${section.slug}/`} class="section-card">
            <div class="section-card-top">
              <span class="section-index">{String(index + 1).padStart(2, '0')}</span>
              <span class="section-arrow" aria-hidden="true">↗</span>
            </div>
            <h3>{section.title}</h3>
            <p>{section.description}</p>
            <span class="section-link">{copy.sections.view}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="mission-section">
    <div class="medrese-shell mission-grid">
      <div class="mission-copy section-heading">
        <span class="section-kicker">{copy.mission.eyebrow}</span>
        <h2>{copy.mission.title}</h2>
        <p>{copy.mission.body}</p>
      </div>
      <div class="mission-values">
        {copy.mission.values.map((value, index) => (
          <article>
            <span>{String(index + 1).padStart(2, '0')}</span>
            <div><h3>{value.title}</h3><p>{value.body}</p></div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section id="schedule" class="section-block schedule-section">
    <div class="medrese-shell schedule-layout">
      <div>
        <div class="section-heading">
          <span class="section-kicker">{copy.schedule.eyebrow}</span>
          <h2>{copy.schedule.title}</h2>
          <p>{copy.schedule.body}</p>
        </div>
        <div class="schedule-table">
          {copy.schedule.rows.map((row) => (
            <article>
              <div><strong>{row.day}</strong><small>{row.audience}</small></div>
              <p>{row.activity}</p>
              <time>{row.time}</time>
            </article>
          ))}
        </div>
      </div>

      <aside class="prayer-card">
        <div class="prayer-heading">
          <span>{copy.prayer.label}</span>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M20 15.5A8.5 8.5 0 0 1 8.5 4 8.5 8.5 0 1 0 20 15.5Z"></path></svg>
        </div>
        <p>{copy.prayer.city}</p>
        <div class="prayer-list">
          {copy.prayer.names.map((name, index) => (
            <div class:list={[index === 3 && 'is-next']}>
              <span>{name}</span><strong>{copy.prayer.times[index]}</strong>
            </div>
          ))}
        </div>
        <small>{copy.prayer.note}</small>
      </aside>
    </div>
  </section>

  <section class="events-section">
    <div class="medrese-shell">
      <div class="section-heading">
        <span class="section-kicker">{copy.events.eyebrow}</span>
        <h2>{copy.events.title}</h2>
      </div>
      <div class="event-list">
        {copy.events.items.map((event) => (
          <article>
            <time><strong>{event.day}</strong><span>{event.month}</span></time>
            <div><h3>{event.title}</h3><p>{event.meta}</p></div>
            <a href={`/${lang}/medrese/evenementen/`} aria-label={event.title}>→</a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="ai-section">
    <div class="medrese-shell ai-layout">
      <div class="section-heading">
        <span class="section-kicker">{copy.ai.eyebrow}</span>
        <h2>{copy.ai.title}</h2>
        <p>{copy.ai.body}</p>
        <div class="ai-suggestions">
          {copy.ai.suggestions.map((suggestion) => (
            <button type="button" data-ai-suggestion>{suggestion}</button>
          ))}
        </div>
      </div>
      <div class="ai-card">
        <div class="ai-topbar"><span></span><p>Medrese AI</p><small>DEMO</small></div>
        <form data-ai-form>
          <label>
            <span class="sr-only">{copy.ai.placeholder}</span>
            <input type="text" placeholder={copy.ai.placeholder} data-ai-input />
            <button type="submit" aria-label="Send">↑</button>
          </label>
        </form>
        <div class="ai-answer" data-ai-answer hidden>
          <small>{copy.ai.answerTitle}</small>
          <p>{copy.ai.answer}</p>
          <span>{copy.ai.source}</span>
        </div>
        <p class="ai-disclaimer">{copy.ai.disclaimer}</p>
      </div>
    </div>
  </section>

  <section class="newsletter-section">
    <div class="medrese-shell newsletter-inner">
      <div><h2>{copy.newsletter.title}</h2><p>{copy.newsletter.body}</p></div>
      <form data-newsletter-form>
        <label><span class="sr-only">Email</span><input type="email" required placeholder={copy.newsletter.placeholder} /></label>
        <button type="submit">{copy.newsletter.button}</button>
      </form>
      <p class="newsletter-success" data-newsletter-success hidden>{copy.newsletter.success}</p>
    </div>
  </section>

  <script>
    const aiForm = document.querySelector<HTMLFormElement>('[data-ai-form]');
    const aiInput = document.querySelector<HTMLInputElement>('[data-ai-input]');
    const aiAnswer = document.querySelector<HTMLElement>('[data-ai-answer]');
    document.querySelectorAll<HTMLButtonElement>('[data-ai-suggestion]').forEach((button) => {
      button.addEventListener('click', () => {
