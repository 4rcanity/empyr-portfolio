---
import '../../styles/global.css';
import { languages, type Lang } from '../../i18n/ui';
import PortfolioSEO from '../../components/shared/PortfolioSEO.astro';

export function getStaticPaths() {
  return languages.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Lang };
const copy =
  lang === 'nl'
    ? {
        title: 'Empyr Games — In ontwikkeling',
        description: 'De game-development tak van Empyr is in ontwikkeling. Binnenkort verschijnen hier prototypes, werelden en interactieve ervaringen.',
        eyebrow: 'Empyr / Game development',
        status: 'In ontwikkeling',
        headingA: 'Nieuwe werelden',
        headingB: 'laden...',
        body: 'De game-development tak van Empyr wordt momenteel opgebouwd. Hier verschijnen binnenkort prototypes, systemen en speelbare ervaringen.',
        progress: 'Development status',
        concept: 'Concept & direction',
        systems: 'Gameplay systems',
        world: 'World building',
        back: 'Terug naar webdesign',
        notify: 'Volg de ontwikkeling',
        note: 'Eerste project — binnenkort onthuld',
      }
    : {
        title: 'Empyr Games — Work in progress',
        description: 'The game-development side of Empyr is under construction. Prototypes, worlds and interactive experiences are coming soon.',
        eyebrow: 'Empyr / Game development',
        status: 'Work in progress',
        headingA: 'New worlds',
        headingB: 'loading...',
        body: 'The game-development side of Empyr is currently taking shape. Prototypes, systems and playable experiences will appear here soon.',
        progress: 'Development status',
        concept: 'Concept & direction',
        systems: 'Gameplay systems',
        world: 'World building',
        back: 'Back to web design',
        notify: 'Follow development',
        note: 'First project — reveal coming soon',
      };
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{copy.title}</title>
    <meta name="description" content={copy.description} />
    <PortfolioSEO lang={lang} title={copy.title} description={copy.description} path="/games" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  </head>
  <body class="min-h-screen overflow-x-hidden bg-[#08080b] text-white antialiased" style="font-family: Inter, system-ui, sans-serif;">
    <div class="fixed inset-0 -z-10">
      <div class="absolute left-1/2 top-[-18rem] h-[38rem] w-[38rem] -translate-x-1/2 rounded-full bg-violet-600/20 blur-[120px]"></div>
      <div class="absolute bottom-[-16rem] right-[-8rem] h-[32rem] w-[32rem] rounded-full bg-cyan-500/10 blur-[120px]"></div>
      <div class="game-grid absolute inset-0 opacity-[0.055]"></div>
    </div>

    <header class="border-b border-white/10 bg-black/10 backdrop-blur-xl">
      <div class="mx-auto flex max-w-7xl items-center justify-between px-4 py-4 sm:px-6 lg:px-8">
        <a href={`/${lang}`} class="flex items-center gap-2.5 text-lg font-extrabold tracking-tight text-white">
          <img src="/images/empyr-logo.png" alt="Empyr" class="h-9 w-9 rounded-xl object-cover" width="36" height="36" />
          Empyr
        </a>
        <div class="flex items-center gap-3">
          <span class="hidden rounded-full border border-violet-400/20 bg-violet-400/10 px-3 py-1.5 text-[10px] font-bold uppercase tracking-[0.18em] text-violet-300 sm:inline-flex">
            {copy.status}
          </span>
          <div class="flex items-center gap-1 rounded-full border border-white/10 bg-white/[0.04] p-1 text-xs font-semibold">
            {languages.map((l) => (
              <a
                href={`/${l}/games`}
                class="rounded-full px-3 py-1 transition-colors"
                style={l === lang ? 'background: white; color: #18181b;' : 'color: #a1a1aa;'}
              >
                {l.toUpperCase()}
              </a>
            ))}
          </div>
        </div>
      </div>
    </header>

    <main class="mx-auto grid min-h-[calc(100vh-73px)] max-w-7xl items-center gap-16 px-4 py-16 sm:px-6 lg:grid-cols-[1.05fr_.95fr] lg:px-8 lg:py-20">
      <section>
        <p class="text-xs font-bold uppercase tracking-[0.28em] text-violet-300">{copy.eyebrow}</p>
        <h1 class="mt-6 text-5xl font-semibold leading-[0.95] tracking-[-0.06em] sm:text-7xl lg:text-[5.8rem]">
          {copy.headingA}<br />
          <span class="text-zinc-600">{copy.headingB}</span>
        </h1>
        <p class="mt-7 max-w-xl text-base leading-7 text-zinc-400 sm:text-lg">{copy.body}</p>

        <div class="mt-10 flex flex-col gap-3 sm:flex-row">
          <a href={`/${lang}#work`} class="inline-flex items-center justify-center gap-2 rounded-full bg-white px-6 py-3.5 text-sm font-bold text-zinc-950 transition hover:-translate-y-0.5 hover:bg-violet-50">
            <span aria-hidden="true">←</span> {copy.back}
          </a>
          <a href="mailto:business@empyr-portfolio.com?subject=Empyr%20Games" class="inline-flex items-center justify-center rounded-full border border-white/15 bg-white/[0.04] px-6 py-3.5 text-sm font-bold text-white transition hover:border-violet-400/40 hover:bg-white/[0.08]">
            {copy.notify}
          </a>
        </div>
      </section>

      <section class="relative mx-auto w-full max-w-lg" aria-label={copy.progress}>
        <div class="absolute -inset-8 rounded-full bg-violet-500/10 blur-3xl"></div>
        <div class="relative overflow-hidden rounded-[2rem] border border-white/10 bg-white/[0.055] p-6 shadow-2xl shadow-black/50 backdrop-blur-xl sm:p-8">
          <div class="flex items-center justify-between">
            <div>
              <p class="text-[10px] font-bold uppercase tracking-[0.24em] text-zinc-500">{copy.progress}</p>
              <p class="mt-2 text-xl font-semibold">{copy.note}</p>
            </div>
            <span class="relative flex h-3 w-3">
              <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-violet-400 opacity-50"></span>
              <span class="relative inline-flex h-3 w-3 rounded-full bg-violet-400"></span>
            </span>
          </div>

          <div class="relative mt-10 aspect-square overflow-hidden rounded-[1.5rem] border border-white/10 bg-black/30">
            <div class="game-grid absolute inset-0 opacity-20"></div>
            <div class="absolute inset-0 flex items-center justify-center">
              <div class="relative h-44 w-44">
                <div class="absolute inset-0 rotate-45 rounded-[2rem] border border-violet-400/30"></div>
                <div class="absolute inset-5 -rotate-12 rounded-[1.6rem] border border-cyan-300/20"></div>
                <div class="absolute inset-10 flex items-center justify-center rounded-2xl bg-gradient-to-br from-violet-500 to-fuchsia-500 shadow-2xl shadow-violet-500/30">
                  <span class="text-5xl font-black italic tracking-[-0.08em]">E</span>
                </div>
              </div>
            </div>
            <span class="absolute bottom-5 left-5 rounded-full border border-white/10 bg-black/30 px-3 py-1.5 text-[10px] font-bold uppercase tracking-[0.18em] text-zinc-400 backdrop-blur">
              Build 0.0.1
            </span>
          </div>

          <div class="mt-8 space-y-5">
            {[
              { label: copy.concept, value: 72 },
              { label: copy.systems, value: 28 },
              { label: copy.world, value: 16 },
            ].map((item) => (
              <div>
                <div class="mb-2 flex items-center justify-between text-xs font-semibold text-zinc-400">
                  <span>{item.label}</span>
                  <span>{item.value}%</span>
                </div>
                <div class="h-1.5 overflow-hidden rounded-full bg-white/10">
                  <div class="h-full rounded-full bg-gradient-to-r from-violet-500 to-cyan-400" style={`width: ${item.value}%`}></div>
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>
    </main>

    <style>
      .game-grid {
        background-image:
          linear-gradient(rgba(255, 255, 255, 0.7) 1px, transparent 1px),
          linear-gradient(90deg, rgba(255, 255, 255, 0.7) 1px, transparent 1px);
        background-size: 52px 52px;
        mask-image: radial-gradient(circle at center, black, transparent 75%);
      }
    </style>
  </body>
</html>
