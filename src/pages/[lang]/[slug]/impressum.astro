---
import LegalPage from '../../../components/shared/LegalPage.astro';
import { configs } from '../../../data/configs';
import { languages } from '../../../i18n/ui';

export function getStaticPaths() {
  return languages.flatMap((lang) =>
    configs.map((config) => ({
      params: { lang, slug: config.slug },
      props: { config },
    }))
  );
}

const { lang } = Astro.params;
const { config } = Astro.props;
const content = config.content[lang as 'nl' | 'en'];
---

<LegalPage config={config} content={content} lang={lang as 'nl' | 'en'} page="impressum" />
