---
import '../../styles/global.css';
import { configs } from '../../data/configs';
import { languages, type Lang } from '../../i18n/ui';
import { useTranslations } from '../../i18n/utils';
import PricingComparison from '../../components/shared/PricingComparison.astro';
import PortfolioSEO from '../../components/shared/PortfolioSEO.astro';
import PortfolioChooser from '../../components/shared/PortfolioChooser.astro';
import ProjectIcon from '../../components/portfolio/ProjectIcon.astro';

export function getStaticPaths() {
  return languages.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Lang };
const t = useTranslations(lang);

const templateMeta: Record<string, { bestFor: string[]; nlBestFor: string[] }> = {
  trattoria: {
    bestFor: ['Italian restaurants', 'Family dining', '100% Halal'],
    nlBestFor: ['Italiaanse restaurants', 'Familierestaurants', '100% halal'],
  },
  noir: {
    bestFor: ['Fine dining', 'Alcohol-free', '100% Halal'],
    nlBestFor: ['Fine dining', 'Alcoholvrij', '100% halal'],
  },
  corner: {
    bestFor: ['Cafés', 'Brunch spots', '100% Halal'],
    nlBestFor: ['Cafés', 'Brunchzaken', '100% halal'],
  },
  ocakbasi: {
    bestFor: ['Turkish grill', 'Kebab & döner', '100% Halal'],
    nlBestFor: ['Turkse grill', 'Kebab & döner', '100% halal'],
  },
  barberhouse: {
    bestFor: ['Barbershops', 'Hair salons', 'Grooming studios'],
    nlBestFor: ['Kapperszaken', 'Barbershops', 'Grooming studio\'s'],
  },
};

const templates = [
  ...configs.map((config) => {
    const content = config.content[lang];
    const meta = templateMeta[config.slug];
    return {
      slug: config.slug,
      name: config.name,
      tagline: content.tagline,
      description: content.description,
      accent: config.theme.accent,
      bestFor: lang === 'nl' ? meta.nlBestFor : meta.bestFor,
    };
  }),
  {
    slug: 'medrese',
    name: 'Medrese',
    tagline: lang === 'nl' ? 'Kennis die hart en verstand verbindt' : 'Knowledge that connects heart and mind',
    description:
      lang === 'nl'
        ? 'Een meertalig educatief platform voor islamitische basiskennis, Koran, hadith, Risale-i Nur, lessen en activiteiten.'
        : 'A multilingual learning platform for Islamic foundations, Quran, hadith, Risale-i Nur, classes and activities.',
    accent: '#BD8B35',
    bestFor:
      lang === 'nl'
        ? ['Educatie', 'Gemeenschap', 'NL · TR · EN']
        : ['Education', 'Community', 'NL · TR · EN'],
  },
];

const copy =
  lang === 'nl'
    ? {
        featurePills: ['Mobielvriendelijk', 'AVG-vriendelijk', 'Meertalig'],
        heroEyebrow: 'Design & development studio',
        heroLead: 'Digitale ervaringen met karakter.',
        heroBody:
          'Empyr ontwerpt snelle, onderscheidende websites voor ambitieuze lokale ondernemers — van eerste concept tot live product.',
        primaryCta: 'Ontdek het werk',
        secondaryCta: 'Start een project',
        workEyebrow: 'Geselecteerd werk',
        workTitle: 'Gebouwd om op te vallen.',
        workBody: 'Zes concepten, elk met een eigen merkgevoel, doelgroep en conversiedoel.',
        games: 'Game development',
        contactTitle: 'Klaar om te beginnen?',
        contactSubtitle: 'Neem contact op en we bouwen jouw website of webapp binnen een week.',
        whatsAppMessage:
          'Hoi Empyr! Ik ben geïnteresseerd in een website/webapp. Kunnen we even praten over mijn project?',
      }
    : {
        featurePills: ['Mobile-first', 'GDPR-friendly', 'Multilingual'],
        heroEyebrow: 'Design & development studio',
        heroLead: 'Digital experiences with character.',
        heroBody:
          'Empyr designs fast, distinctive websites for ambitious local businesses — from first concept to live product.',
        primaryCta: 'Explore the work',
        secondaryCta: 'Start a project',
        workEyebrow: 'Selected work',
        workTitle: 'Built to stand out.',
        workBody: 'Six concepts, each with its own brand feel, audience and conversion goal.',
        games: 'Game development',
        contactTitle: 'Ready to get started?',
        contactSubtitle: "Get in touch and we'll have your site or web app live within a week.",
        whatsAppMessage:
          'Hi Empyr! I am interested in a website/web app. Can we talk about my project?',
      };

const pageTitle = 'Empyr Portfolio — Websites & Web Apps';
const pageDescription =
  lang === 'nl'
    ? 'Empyr Portfolio — professionele websites en webapps voor lokale ondernemers. Snel, mobielvriendelijk en gebouwd met Astro.'
    : 'Empyr Portfolio — professional websites and web apps for local businesses. Fast, mobile-first, and built with Astro.';

const whatsAppUrl = `https://wa.me/31638269872?text=${encodeURIComponent(copy.whatsAppMessage)}`;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <PortfolioSEO lang={lang} title={pageTitle} description={pageDescription} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  </head>
  <body class="min-h-screen bg-[#0c0a09] text-stone-100 antialiased" style="font-family: Inter, system-ui, sans-serif;">
    <PortfolioChooser lang={lang} />

    <header class="sticky top-0 z-50 border-b border-white/10 bg-[#0c0a09]/80 backdrop-blur-xl">
      <div class="mx-auto flex max-w-7xl items-center justify-between px-4 py-4 sm:px-6 lg:px-8">
        <a href={`/${lang}`} class="flex items-center gap-2.5 text-lg font-extrabold tracking-tight text-white">
          <img
            src="/images/empyr-logo.png"
            alt="Empyr"
            class="h-9 w-9 rounded-xl object-cover"
            width="36"
            height="36"
          />
          Empyr
        </a>
        <div class="flex items-center gap-3 sm:gap-4">
          <a href={`/${lang}/games`} class="hidden text-sm font-medium text-stone-400 transition hover:text-white md:block">
            {copy.games}
          </a>
          <div class="flex items-center gap-1 rounded-full border border-white/10 bg-white/[0.04] px-1 py-1 text-xs font-semibold">
            {languages.map((l) => (
              <a
                href={`/${l}`}
                class="rounded-full px-3 py-1 transition-colors"
                style={l === lang ? 'background: white; color: #1c1917;' : 'color: #a8a29e;'}
              >
                {l.toUpperCase()}
              </a>
            ))}
          </div>
          <a href="#contact" class="hidden rounded-full bg-orange-500 px-5 py-2.5 text-sm font-semibold text-white shadow-lg shadow-orange-500/20 transition hover:-translate-y-0.5 hover:bg-orange-400 sm:inline-flex">
            {copy.secondaryCta}
          </a>
        </div>
      </div>
    </header>

    <main>
    <section class="relative isolate overflow-hidden">
      <div class="pointer-events-none absolute left-1/2 top-[-20rem] h-[42rem] w-[42rem] -translate-x-1/2 rounded-full bg-orange-500/20 blur-[120px]"></div>
      <div class="pointer-events-none absolute right-[-12rem] top-32 h-96 w-96 rounded-full bg-rose-500/10 blur-[110px]"></div>
      <div class="absolute inset-0 -z-10 opacity-[0.035]" style="background-image: linear-gradient(rgba(255,255,255,.8) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,.8) 1px, transparent 1px); background-size: 64px 64px;"></div>

      <div class="relative mx-auto grid min-h-[82vh] max-w-7xl items-center gap-14 px-4 py-20 sm:px-6 sm:py-28 lg:grid-cols-[1.1fr_.9fr] lg:px-8">
        <div>
          <span class="inline-flex items-center gap-2 rounded-full border border-orange-400/20 bg-orange-400/10 px-4 py-2 text-xs font-bold uppercase tracking-[0.22em] text-orange-300">
            <span class="h-1.5 w-1.5 rounded-full bg-orange-400 shadow-[0_0_12px_#fb923c]"></span>
            {copy.heroEyebrow}
          </span>
          <h1 class="mt-7 max-w-4xl text-5xl font-semibold leading-[0.95] tracking-[-0.06em] text-white sm:text-7xl lg:text-[5.7rem]">
            {copy.heroLead}
          </h1>
          <p class="mt-7 max-w-2xl text-base leading-7 text-stone-400 sm:text-lg">{copy.heroBody}</p>

          <div class="mt-9 flex flex-col gap-3 sm:flex-row">
            <a href="#work" class="inline-flex items-center justify-center gap-2 rounded-full bg-white px-6 py-3.5 text-sm font-bold text-stone-950 transition hover:-translate-y-0.5 hover:bg-orange-50">
              {copy.primaryCta} <span aria-hidden="true">↓</span>
            </a>
            <a href="#contact" class="inline-flex items-center justify-center rounded-full border border-white/15 bg-white/[0.04] px-6 py-3.5 text-sm font-bold text-white transition hover:border-white/30 hover:bg-white/[0.08]">
              {copy.secondaryCta}
            </a>
          </div>

          <div class="mt-10 flex flex-wrap gap-2">
          {copy.featurePills.map((pill) => (
              <span class="rounded-full border border-white/10 px-3 py-1.5 text-xs font-medium text-stone-400">{pill}</span>
          ))}
          </div>
        </div>

        <div class="relative mx-auto w-full max-w-lg">
          <div class="absolute -inset-8 rounded-full bg-orange-500/10 blur-3xl"></div>
          <div class="relative rotate-2 overflow-hidden rounded-[2.2rem] border border-white/10 bg-white/[0.06] p-3 shadow-2xl shadow-black/40 backdrop-blur">
            <div class="overflow-hidden rounded-[1.65rem] bg-stone-950">
              <div class="flex items-center gap-2 border-b border-white/10 px-5 py-4">
                <span class="h-2.5 w-2.5 rounded-full bg-rose-400"></span>
                <span class="h-2.5 w-2.5 rounded-full bg-amber-300"></span>
                <span class="h-2.5 w-2.5 rounded-full bg-emerald-400"></span>
                <span class="ml-3 text-[10px] font-semibold uppercase tracking-[0.2em] text-stone-600">Empyr / Selected work</span>
              </div>
              <div class="grid grid-cols-2 gap-3 p-3">
                {templates.slice(0, 4).map((tpl, index) => (
                  <a href={`/${lang}/${tpl.slug}`} class:list={["group relative overflow-hidden rounded-2xl", index === 0 && "col-span-2 aspect-[2/1]", index !== 0 && "aspect-square"]}>
                    <ProjectIcon slug={tpl.slug} name={tpl.name} compact={true} />
                    <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-transparent to-transparent"></div>
                    <span class="absolute bottom-3 left-3 text-xs font-bold text-white">{tpl.name}</span>
                  </a>
                ))}
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section id="work" class="bg-stone-50 py-24 text-stone-950 sm:py-32">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="max-w-3xl">
          <p class="text-xs font-bold uppercase tracking-[0.24em] text-orange-600">{copy.workEyebrow}</p>
          <h2 class="mt-4 text-4xl font-semibold tracking-[-0.05em] sm:text-6xl">{copy.workTitle}</h2>
          <p class="mt-5 max-w-2xl text-base leading-7 text-stone-600">{copy.workBody}</p>
        </div>

      <div class="mt-14 grid gap-6 sm:grid-cols-2 lg:grid-cols-6">
        {templates.map((tpl) => (
          <article class="group relative col-span-2 flex flex-col overflow-hidden rounded-[2rem] border border-stone-200 bg-white shadow-sm transition-all duration-500 hover:-translate-y-1.5 hover:shadow-2xl lg:[&:nth-child(-n+2)]:col-span-3">
            <div class="relative aspect-[4/3] overflow-hidden bg-stone-200">
              <ProjectIcon slug={tpl.slug} name={tpl.name} />
              <span
                class="absolute left-5 top-5 rounded-full border border-white/20 bg-black/25 px-3 py-1.5 text-[10px] font-bold uppercase tracking-wider text-white backdrop-blur-md"
              >
                {tpl.name}
              </span>
            </div>
            <div class="flex flex-1 flex-col p-7">
              <p class="text-lg font-semibold tracking-tight text-stone-900">{tpl.tagline}</p>
              <p class="mt-3 flex-1 text-sm leading-6 text-stone-500">{tpl.description}</p>
              <ul class="mt-4 flex flex-wrap gap-2">
                {tpl.bestFor.map((tag) => (
                  <li class="rounded-full border border-stone-200 bg-stone-50 px-3 py-1 text-[11px] font-medium text-stone-600">{tag}</li>
                ))}
              </ul>
              <a
                href={`/${lang}/${tpl.slug}`}
                class="mt-7 inline-flex items-center gap-2 text-sm font-bold text-stone-900 transition-colors hover:text-orange-600"
              >
                {t('portfolio.viewDemo')} <span class="transition-transform group-hover:translate-x-1" aria-hidden="true">↗</span>
              </a>
            </div>
          </article>
        ))}
      </div>
      </div>
    </section>

    <PricingComparison lang={lang} />

    <section id="contact" class="bg-stone-900 py-24 text-center">
      <div class="mx-auto max-w-2xl px-4 sm:px-6">
        <h2 class="text-3xl font-bold text-white sm:text-4xl">{copy.contactTitle}</h2>
        <p class="mt-4 text-stone-300">{copy.contactSubtitle}</p>
        <p class="mt-8 text-sm italic text-stone-400">{t('portfolio.pitch')}</p>
        <div class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row">
          <a
            href={whatsAppUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center gap-2 rounded-full bg-[#25D366] px-8 py-3.5 text-base font-semibold text-white shadow-lg shadow-[#25D366]/30 transition-colors hover:bg-[#20bd5a]"
          >
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-5 w-5" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.435 9.884-9.882 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            {t('portfolio.contactWhatsApp')}
          </a>
          <a
            href="mailto:business@empyr-portfolio.com"
            class="inline-flex items-center justify-center rounded-full border border-stone-600 bg-transparent px-8 py-3.5 text-base font-semibold text-white transition-colors hover:border-stone-400 hover:bg-stone-800"
          >
            {t('portfolio.contactEmail')}
          </a>
        </div>
      </div>
    </section>
    </main>

    <footer class="border-t border-white/10 bg-[#0c0a09] py-8 text-center text-sm text-stone-500">
      {t('portfolio.footer')}
    </footer>
  </body>
</html>
