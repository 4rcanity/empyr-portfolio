# Clerk (https://dashboard.clerk.com)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Supabase (https://app.supabase.com)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# AI site generator (OpenAI-compatible)
# Providers: deepseek | glm | ollama | placeholder
LLM_PROVIDER=deepseek
LLM_API_KEY=
# Optional aliases (used if LLM_API_KEY is empty)
DEEPSEEK_API_KEY=
ZHIPU_API_KEY=
# Defaults: deepseek-v4-flash | glm-4-flash | deepseek-coder-v2-lite (ollama)
LLM_MODEL=
# Optional override base URL (Ollama: http://127.0.0.1:11434/v1)
LLM_BASE_URL=
